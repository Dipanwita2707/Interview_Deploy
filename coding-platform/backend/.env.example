# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/coding_platform
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6380

# JWT - Coding platform session tokens
JWT_SECRET=your-coding-platform-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h

# SMART SSO Integration
SMART_SSO_SECRET=shared-secret-with-smart-backend
SMART_API_URL=http://localhost:4000

# Judge0
JUDGE0_URL=http://localhost:2358
JUDGE0_API_KEY=

# BullMQ
BULLMQ_CONCURRENCY=5

# Cache TTLs (seconds)
PERMISSION_CACHE_TTL=300
STUDENT_CONTEXT_CACHE_TTL=600
