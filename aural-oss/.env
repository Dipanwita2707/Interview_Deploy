# ──────────────────────────────────────
# Voice Relay
# ──────────────────────────────────────
VOICE_RELAY_PORT=8081
OPENAI_VOICE_RELAY_PORT=8082

# Voice relay URLs (used by the frontend)
NEXT_PUBLIC_VOICE_RELAY_URL=ws://localhost:8081
NEXT_PUBLIC_OPENAI_VOICE_RELAY_URL=ws://localhost:8082

# Which voice relay to use as primary: "auto" | "voice" | "openai"
# NEXT_PUBLIC_VOICE_RELAY_PRIMARY=auto

# ──────────────────────────────────────
# Voice Relay LLM (for in-relay summarization)
# ──────────────────────────────────────
# Falls back to KIMI/MINIMAX keys if not set
# RELAY_LLM_API_KEY=
# RELAY_LLM_BASE_URL=
# RELAY_LLM_MODEL=

# ASR provider for OpenAI voice relay: "openai" (default)
# VOICE_ASR_PRIMARY=openai
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=whisper-1

# ──────────────────────────────────────
# Azure OpenAI Realtime (for voice relay)
# ──────────────────────────────────────
